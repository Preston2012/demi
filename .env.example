# Demiurge Configuration
PORT=3100
HOST=127.0.0.1
AUTH_TOKEN=your-auth-token-here-min-32-chars

# Database
DB_PATH=./data/demiurge.db
WAL_MODE=true

# Embeddings
MODEL_PATH=./models/bge-small-en-v1.5.onnx
EMBEDDING_DIM=384
EMBEDDING_QUEUE_SIZE=100

# Retrieval
LEXICAL_WEIGHT=0
VECTOR_WEIGHT=1.0
MAX_INJECTED_RULES=65
CANDIDATE_OVERFETCH_MULTIPLIER=5
FRESHNESS_HALF_LIFE_DAYS=14

# Trust branching
CONFIDENCE_THRESHOLD=0.7
SPOT_CHECK_RATE=0.1
CONSENSUS_THRESHOLD=0.5
CONSENSUS_MIN_AGREEMENT=2

# API keys (required for write consensus + answer generation)
OPENAI_API_KEY=your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key
XAI_API_KEY=your-xai-key
GOOGLE_API_KEY=your-google-key

# Consensus
CONSENSUS_PROVIDER=openai
CONSENSUS_MODEL=gpt-4.1-mini
CONSENSUS_EVALUATORS=openai:gpt-4.1-mini,google:gemini-2.5-flash,anthropic:claude-haiku-4-5-20251001

# Feature flags
SQL_FIRST_ROUTING=false
ANSWER_ROUTING=true
ANSWER_ESCALATION_ENABLED=true
FACT_DEDUP=true
STONE_ENABLED=true
TEMPORAL_ENABLED=true
THOMPSON_SHADOW_ENABLED=false
TEST_MODE=false

# Logging
LOG_LEVEL=info
