{
  "name": "demiurge",
  "version": "1.0.0",
  "description": "Adaptive memory for AI agents. Quality-gated, refusal-first.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "demiurge": "./bin/demiurge"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "backup": "bash scripts/backup.sh",
    "export": "bash scripts/export-brain.sh",
    "setup": "bash scripts/setup.sh",
    "benchmark": "tsx scripts/benchmark.ts",
    "benchmark:smoke": "tsx scripts/benchmark.ts smoke-test",
    "benchmark:locomo": "tsx scripts/benchmark.ts locomo-v1",
    "benchmark:longmemeval-extract": "tsx scripts/benchmark.ts longmemeval-extract",
    "benchmark:longmemeval": "tsx scripts/benchmark.ts longmemeval-s",
    "benchmark:locomo-official": "tsx scripts/benchmark-locomo-official.ts",
    "scorecard": "tsx scripts/scorecard/scorecard.ts",
    "scorecard:gate": "tsx scripts/scorecard/gate.ts",
    "scorecard:analyze": "tsx scripts/scorecard/analyze.ts",
    "claims:compile": "node scripts/claims-compile.mjs",
    "self-play": "tsx scripts/benchmark.ts self-play",
    "eval:supersession": "tsx scripts/eval-supersession.ts",
    "analyze:weights": "tsx scripts/analyze-retrieval-weights.ts",
    "sbom": "bash scripts/generate-sbom.sh",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=24.7.0"
  },
  "dependencies": {
    "@huggingface/transformers": "4.2.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3-multiple-ciphers": "12.9.0",
    "chrono-node": "2.9.1",
    "dotenv": "16.6.1",
    "fastify": "5.8.5",
    "onnxruntime-node": "1.24.3",
    "pino": "9.14.0",
    "sqlite-vec": "0.1.9",
    "uuid": "10.0.0",
    "zod": "3.25.76"
  },
  "overrides": {
    "fast-uri": "3.1.2"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "4.2.1",
    "@eslint/js": "10.0.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/js-yaml": "4.0.9",
    "@types/node": "22.19.17",
    "@types/uuid": "10.0.0",
    "@vitest/coverage-v8": "2.1.9",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "js-yaml": "4.2.0",
    "lint-staged": "16.4.0",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.1",
    "vitest": "2.1.9"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "author": "Preston Winters",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Preston2012/demiurge.git"
  }
}
