{
  "name": "demiurge",
  "version": "1.0.0",
  "description": "Adaptive memory for AI agents. Quality-gated, refusal-first.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "backup": "bash scripts/backup.sh",
    "export": "bash scripts/export-brain.sh",
    "setup": "bash scripts/setup.sh",
    "benchmark": "tsx scripts/benchmark.ts",
    "benchmark:smoke": "tsx scripts/benchmark.ts smoke-test",
    "benchmark:locomo": "tsx scripts/benchmark.ts locomo-v1",
    "benchmark:longmemeval-extract": "tsx scripts/benchmark.ts longmemeval-extract",
    "benchmark:longmemeval": "tsx scripts/benchmark.ts longmemeval-s",
    "benchmark:locomo-official": "tsx scripts/benchmark-locomo-official.ts",
    "self-play": "tsx scripts/benchmark.ts self-play",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.2.0",
    "onnxruntime-node": "^1.21.0",
    "pino": "^9.6.0",
    "sqlite-vec": "^0.1.6",
    "uuid": "^10.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^2.1.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "author": "Preston Winters",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Preston2012/demiurge.git"
  }
}
